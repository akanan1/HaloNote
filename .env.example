# Copy to .env at the workspace root and fill in real values for local dev.
# Production environments inject these directly — do NOT commit a real .env.

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
# Port both api-server and mockup-sandbox listen on. They can't run
# simultaneously without overriding one — set per-shell when running both.
PORT=8080

# Postgres connection string for @workspace/db (Drizzle).
DATABASE_URL=postgres://user:password@localhost:5432/halonote

# Separate Postgres database used by the integration test harness in
# artifacts/api-server. The harness will TRUNCATE all tables in this DB
# between tests — point it at a throwaway database, NEVER your dev DB.
# Create it with `createdb halonote_test` (or `CREATE DATABASE halonote_test;`).
TEST_DATABASE_URL=postgres://user:password@localhost:5432/halonote_test

# Log verbosity for the api-server (silent|fatal|error|warn|info|debug|trace).
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins for the api-server.
# Leave unset in development to allow all origins; required in production.
# CORS_ORIGIN=https://app.halonote.example,https://admin.halonote.example

# ----------------------------------------------------------------------------
# Frontend (mockup-sandbox)
# ----------------------------------------------------------------------------
# Vite base path. Use "/" for local dev.
BASE_PATH=/

# ----------------------------------------------------------------------------
# EHR push mode
# ----------------------------------------------------------------------------
# Controls where POST /api/notes/{id}/send-to-ehr actually posts.
#   - unset / anything else  → mock (logs the DocumentReference, returns a
#                              synthetic id). Safe default for local dev.
#   - "athenahealth"         → real Athena push (requires ATHENA_* below).
#   - "epic"                 → not yet implemented in the api-server.
EHR_MODE=

# ----------------------------------------------------------------------------
# Athenahealth EHR (OAuth2 client_credentials)
# ----------------------------------------------------------------------------
ATHENA_FHIR_BASE_URL=
ATHENA_TOKEN_URL=
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=
# Optional space-separated scopes.
ATHENA_SCOPE=

# ----------------------------------------------------------------------------
# Epic EHR (SMART backend services, JWT bearer)
# ----------------------------------------------------------------------------
EPIC_FHIR_BASE_URL=
EPIC_TOKEN_URL=
EPIC_CLIENT_ID=
# PEM-encoded private key, or use a KMS-backed signer in code instead.
EPIC_PRIVATE_KEY=
# Key ID registered in the JWKS Epic fetches (required so Epic picks the right key).
EPIC_KEY_ID=
# Signing algorithm — one of RS256/RS384/RS512/ES256/ES384/ES512.
EPIC_ALGORITHM=RS384
# Optional override for the `aud` claim. Defaults to EPIC_TOKEN_URL.
EPIC_AUDIENCE=
EPIC_SCOPE=
