# Copy to .env at the workspace root and fill in real values for local dev.
# Production environments inject these directly — do NOT commit a real .env.

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
# Port both api-server and mockup-sandbox listen on. They can't run
# simultaneously without overriding one — set per-shell when running both.
PORT=8080

# Postgres connection string for @workspace/db (Drizzle).
DATABASE_URL=postgres://user:password@localhost:5432/halonote

# Separate Postgres database used by the integration test harness in
# artifacts/api-server. The harness will TRUNCATE all tables in this DB
# between tests — point it at a throwaway database, NEVER your dev DB.
# Create it with `createdb halonote_test` (or `CREATE DATABASE halonote_test;`).
TEST_DATABASE_URL=postgres://user:password@localhost:5432/halonote_test

# Log verbosity for the api-server (silent|fatal|error|warn|info|debug|trace).
LOG_LEVEL=info

# Gates dev-only mounts: /api/auth/dev-login (unauthenticated session
# mint), /api/auth/ehr/:provider/dev-start (CSRF-free OAuth start for
# browser-driven E2E), /api/dev/sandbox-patients. Double-gated — also
# requires NODE_ENV != "production". MUST NEVER be set in production:
# enabling it ships an auth bypass. Leave unset (or anything other than
# "1") to keep the routes off.
ALLOW_DEV_ROUTES=

# Comma-separated list of allowed CORS origins for the api-server.
# Leave unset in development to allow all origins; required in production.
# CORS_ORIGIN=https://app.halonote.example,https://admin.halonote.example

# Number of trusted reverse-proxy hops in front of the api-server.
# Set to 1 when behind a single proxy (nginx, Cloudflare, Vercel, etc.)
# so req.ip reflects the real client and per-IP rate limits work.
# Leave at 0 (or unset) for direct connections.
TRUST_PROXY_HOPS=0

# Max milliseconds to wait for in-flight requests to drain on SIGTERM.
# Defaults to 10 seconds; tune to your slowest request.
SHUTDOWN_DRAIN_MS=10000

# Days to retain audit_log rows. The api-server runs cleanup once on
# boot and then daily. Default 2555 (~7 years) sits above the 6-year
# HIPAA minimum at 45 CFR 164.530(j). Set to 0 to disable cleanup
# entirely (treat the table as append-only forever).
AUDIT_LOG_RETENTION_DAYS=2555

# ----------------------------------------------------------------------------
# Outbound email
# ----------------------------------------------------------------------------
# Controls which provider sends auth emails (password reset links, etc.).
#   - unset / anything else  → log-only sink (dev default). The reset URL
#                              is written to the pino log and captured by
#                              the integration test buffer; no real send.
#   - "resend"               → real email via Resend (requires both
#                              RESEND_API_KEY and EMAIL_FROM).
EMAIL_PROVIDER=
RESEND_API_KEY=
# Verified Resend sender, e.g. "HaloNote <auth@halonote.example>".
EMAIL_FROM=

# ----------------------------------------------------------------------------
# Frontend (mockup-sandbox)
# ----------------------------------------------------------------------------
# Vite base path. Use "/" for local dev.
BASE_PATH=/

# ----------------------------------------------------------------------------
# Ambient recording pipeline (audio → transcript → structured SOAP note)
# ----------------------------------------------------------------------------
# Selects which implementation backs POST /api/recordings/:id/finalize.
#   - unset / "auto"  → real pipeline when both keys below are set,
#                       otherwise placeholder. Safe default for local dev.
#   - "placeholder"   → fake delays + canned SOAP body. No external calls.
#                       Used in CI and dev without API keys.
#   - "real"          → live Deepgram (STT) + Anthropic (Claude Opus 4.7).
#                       Throws on boot if either key below is missing —
#                       prevents prod from silently falling back to fake
#                       notes if a key rotation breaks.
RECORDING_PIPELINE=

# Anthropic API key for the Claude Opus 4.7 structuring pass. **BAA
# REQUIRED** before piping any PHI through this key — contact
# legal@anthropic.com. Production keys live in a secrets manager.
ANTHROPIC_API_KEY=

# Deepgram API key for the medical STT model (`nova-3-medical`). **BAA
# REQUIRED** — Deepgram offers one on paid plans; ask your account rep.
# Free-tier keys WILL work technically, but are not HIPAA-compliant and
# must never be used with real audio.
DEEPGRAM_API_KEY=

# ----------------------------------------------------------------------------
# EHR push mode
# ----------------------------------------------------------------------------
# Controls where POST /api/notes/{id}/send-to-ehr actually posts.
#   - unset / anything else  → mock (logs the DocumentReference, returns a
#                              synthetic id). Safe default for local dev.
#   - "athenahealth"         → real Athena push (requires ATHENA_* below).
#   - "epic"                 → real Epic push via SMART backend services
#                              (requires EPIC_* below).
EHR_MODE=

# ----------------------------------------------------------------------------
# Athenahealth EHR (OAuth2 client_credentials)
# ----------------------------------------------------------------------------
ATHENA_FHIR_BASE_URL=
ATHENA_TOKEN_URL=
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=
# Space-separated SMART scopes. Include `offline_access` if you want
# Athena to issue a refresh_token alongside the access token — required
# for the user-facing SMART flow below to silently re-mint expired
# tokens. Typical value:
#   openid fhirUser launch/patient patient/*.read offline_access
ATHENA_SCOPE=

# ----------------------------------------------------------------------------
# Athenahealth EHR (chart REST API — diagnosis/procedure/problem writeback)
# ----------------------------------------------------------------------------
# The chart write endpoints live at a DIFFERENT host than the FHIR base
# (proprietary /v1/{practiceId}/... surface). Read by
# artifacts/api-server/src/lib/athena-chart-api.ts on first call.
#
# Sensible default if unset: https://api.preview.platform.athenahealth.com
ATHENA_CHART_BASE_URL=

# Practice id used by the chart-API client when EHR_MODE=athenahealth.
# Required for any real-mode write (diagnosis, procedure, problem, order).
ATHENA_PRACTICE_ID=

# ----------------------------------------------------------------------------
# Athenahealth sandbox (scripts/ — smoke + write-probe + chart-write-verify)
# ----------------------------------------------------------------------------
# Used ONLY by the @workspace/scripts package. Kept separate from the
# prod ATHENA_CLIENT_ID / ATHENA_CLIENT_SECRET above so a script run
# can never accidentally touch the production practice.
ATHENA_SANDBOX_CLIENT_ID=
ATHENA_SANDBOX_CLIENT_SECRET=
ATHENA_SANDBOX_SCOPE=
ATHENA_SANDBOX_PRACTICE_ID=

# Required by scripts/src/athena-chart-write-verify.ts: a sandbox patient
# with an OPEN encounter. The script POSTs benign Z00.00 / 99213 records
# against this encounter to learn which chart-API param names Athena
# accepts in this practice. Sandbox-only — never set to prod ids.
ATHENA_SANDBOX_TEST_PATIENT_ID=
ATHENA_SANDBOX_TEST_ENCOUNTER_ID=

# ----------------------------------------------------------------------------
# Athenahealth EHR (SMART on FHIR — user-facing Authorization Code + PKCE)
# ----------------------------------------------------------------------------
# Used by POST /api/auth/ehr/athenahealth/start +
# GET /api/auth/ehr/callback. Reuses ATHENA_CLIENT_ID,
# ATHENA_CLIENT_SECRET, ATHENA_FHIR_BASE_URL, ATHENA_TOKEN_URL, and
# ATHENA_SCOPE from the section above.

# MUST match exactly the redirect URI registered with Athena for this
# client (down to scheme, host, port, path, and trailing slash). Athena
# rejects the authorize request on any mismatch. Local dev typically:
#   http://localhost:8080/api/auth/ehr/callback
ATHENA_REDIRECT_URI=

# Optional. The start route defaults this by replacing `/token` with
# `/authorize` on ATHENA_TOKEN_URL (Athena keeps them at sibling paths).
# Set explicitly only if your deployment puts the authorize endpoint
# somewhere else.
ATHENA_AUTHORIZE_URL=

# AES-256-GCM key used to encrypt OAuth access + refresh tokens at rest
# in ehr_connections. MUST be the base64 encoding of exactly 32 random
# bytes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in every environment — the api-server throws on the first
# token write if unset, and the error message escalates in production.
# Treat as a top-tier secret: anyone with this key can decrypt every
# stored OAuth token. Rotation today requires users to re-OAuth.
EHR_TOKEN_ENC_KEY=

# ----------------------------------------------------------------------------
# Cerner / Oracle Health (SMART on FHIR — EHR launch, single-tenant pilot)
# ----------------------------------------------------------------------------
# Used by GET /api/auth/ehr/cerner/launch?iss=...&launch=...
# (the URL registered as the "Launch URL" in Cerner's app gallery).
# Tokens reuse the same encrypted-at-rest path as Athena, keyed under
# provider="cerner" in the ehr_connections table.
#
# Resident workflow: open patient encounter in Cerner PowerChart →
# click the HaloNote SMART app icon → Cerner redirects the browser
# to GET /api/auth/ehr/cerner/launch → HaloNote runs the OAuth
# handshake → lands the resident on /patients/<id>/notes/new with
# the EHR patient + encounter context preloaded.

# FHIR R4 base for your Cerner tenant. The incoming `iss` query
# parameter is rejected unless it exact-matches this value (trailing
# slash tolerated). Sandbox: https://fhir-ehr-code.cerner.com/r4/<tenant>
CERNER_FHIR_BASE_URL=

# SMART authorize + token endpoints. Same tenant id as above. The
# sandbox values are documented in Cerner's "App Gallery" registration
# UI; production is per-customer.
CERNER_AUTHORIZE_URL=
CERNER_TOKEN_URL=

# Cerner-issued client id from the app registration.
CERNER_CLIENT_ID=

# Leave empty for a public client (PKCE-only). When empty, HaloNote
# sends the token request with the client_id in the body and no
# Authorization header — per SMART for public clients. When set,
# Basic auth is used.
CERNER_CLIENT_SECRET=

# MUST exactly match the redirect URI registered with Cerner. Reuses
# the same callback endpoint Athena uses (the callback routes by
# state-row provider, not by URL).
#   Local dev (with a Cerner-trusted tunnel):
#     https://<your-tunnel>.example/api/auth/ehr/callback
CERNER_REDIRECT_URI=

# Space-separated SMART scopes. `launch` is required for the EHR
# launch flow. `offline_access` enables refresh tokens (matches the
# Athena posture). user/Patient.read + user/Encounter.read cover the
# context-load read; widen this set as the app does more.
CERNER_SCOPE="openid fhirUser launch user/Patient.read user/Encounter.read offline_access"

# ----------------------------------------------------------------------------
# Epic EHR (SMART backend services, JWT bearer)
# ----------------------------------------------------------------------------
EPIC_FHIR_BASE_URL=
EPIC_TOKEN_URL=
EPIC_CLIENT_ID=
# PEM-encoded private key, or use a KMS-backed signer in code instead.
EPIC_PRIVATE_KEY=
# Key ID registered in the JWKS Epic fetches (required so Epic picks the right key).
EPIC_KEY_ID=
# Signing algorithm — one of RS256/RS384/RS512/ES256/ES384/ES512.
EPIC_ALGORITHM=RS384
# Optional override for the `aud` claim. Defaults to EPIC_TOKEN_URL.
EPIC_AUDIENCE=
EPIC_SCOPE=

# ----------------------------------------------------------------------------
# Error tracking (Sentry — optional)
# ----------------------------------------------------------------------------
# When unset, the app runs without telemetry. Set both halves to ship
# events to the same Sentry project from server + browser; PHI is
# scrubbed in beforeSend hooks before transport.
SENTRY_DSN=
# Frontend variant — Vite only exposes vars prefixed with VITE_.
VITE_SENTRY_DSN=
# Override environment tag (else NODE_ENV / Vite mode).
SENTRY_ENVIRONMENT=
VITE_SENTRY_ENVIRONMENT=
# Performance sampling — 0 disables tracing. Anything > 0 ships spans.
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
